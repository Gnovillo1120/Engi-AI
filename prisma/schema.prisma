generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String
  firstName   String?
  lastName    String?
  targetRole  String   @default("AI Engineering Intern")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}